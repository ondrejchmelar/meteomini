/*
  Meteomini - Sensor station for ESP32 with SGP41, SCD41 and BME688 sensors
  ---------------------------------------------------------
  Author: kabelkao, modified by ondrejchmelar

  PROGRAM LOGIC:
  ----------------
  1. On startup, ESP32 enables sensor power.
  2. Initializes the I2C bus and connected sensors (BME688 - temperature/humidity/quality, SCD41 - CO2, SGP41 - VOC/NOX).
  3. Runs a self-test on all sensors (on error, power is cut and ESP32 goes to sleep).
  4. Loads the saved VOC algorithm state from NVS memory.
  5. Measures temperature, humidity and air quality via BME688.
  6. Performs 60 VOC measurements using SGP41 with environmental compensation (from BME688); VOC index is computed by the algorithm.
  7. After measurements, saves the VOC algorithm state back to NVS memory.
  8. Obtains a valid CO2, temperature and humidity reading from SCD41 (up to 30s wait).
  9. Cuts sensor power.
  10. Measures battery voltage via a voltage divider and ADC.
  11. Prints all values to the serial port.
  12. If WiFi is connected, sends data to the server via an HTTP GET request.
  13. Finally, puts ESP32 into deep sleep for 10 minutes.
  14. On wake-up, the whole cycle repeats from the beginning.

  HARDWARE:
    - ESP32
    - BME688 (temperature, humidity, air quality)
    - SGP41 (VOC, NOX)
    - SCD41 (CO2)
    - Battery powered (measured via voltage divider)
    - Power enable output (POWER_ENABLE_PIN)
    - I2C bus on pins 18 (SCL) and 19 (SDA)
    - Analog input for battery measurement on pin 0

  SOFTWARE:
    - Libraries used: Adafruit_BME680, SparkFun_SCD4x_Arduino_Library, SensirionI2CSgp41, VOCGasIndexAlgorithm, WiFiManager, HTTPClient, esp_wifi, esp_sleep, Preferences
    - Everything runs in setup(), loop() is empty (runs once then sleeps)
*/

#include <Wire.h>                       // I2C communication
#include <Adafruit_BME680.h>            // BME680/BME688 library
#include "SparkFun_SCD4x_Arduino_Library.h" // SCD41 library
#include "SensirionI2CSgp41.h"          // SGP41 library
#include "VOCGasIndexAlgorithm.h"       // VOC index algorithm
#include <WiFiManager.h>                // Easy WiFi config via AP
#include <HTTPClient.h>                 // HTTP client for sending data
#include <esp_wifi.h>                   // WiFi control (sleep)
#include <esp_sleep.h>                  // Chip sleep
#include <Preferences.h>                // NVS memory for saving algorithm state

// --- Pin and constant definitions ---
#define POWER_ENABLE_PIN 3              // Output for enabling sensor power
#define SDA_PIN 19                      // I2C SDA pin
#define SCL_PIN 18                      // I2C SCL pin

#define ADCBpin 0                       // Analog input for battery measurement
#define bDeviderRatio 1.82274           // Voltage divider ratio for battery measurement

// --- Global objects ---
Adafruit_BME688 bme688;                 // BME688 (temperature, humidity, quality)
SCD4x scd41;                            // SCD41 (CO2)
SensirionI2CSgp41 sgp41;                // SGP41 (VOC, NOX)
VOCGasIndexAlgorithm voc_algorithm;     // VOC index algorithm
Preferences preferences;                // NVS memory object

String serverName = "http://xxxxx.tmep.cz/?"; // Server URL for data upload

// --- Functions for safely loading/saving VOC algorithm state to ESP32 NVS memory ---
void save_voc_state(VOCGasIndexAlgorithm &voc) {
  preferences.begin("sgp41voc", false);
  float voc0, voc1;
  voc.get_states(voc0, voc1);
  preferences.putFloat("voc0", voc0);   // Save state 0
  preferences.putFloat("voc1", voc1);   // Save state 1
  preferences.end();
  Serial.print("Saved VOC state: voc0="); Serial.print(voc0);
  Serial.print(" voc1="); Serial.println(voc1);
}

void load_voc_state(VOCGasIndexAlgorithm &voc) {
  preferences.begin("sgp41voc", true);
  float voc0 = preferences.getFloat("voc0", NAN);
  float voc1 = preferences.getFloat("voc1", NAN);
  preferences.end();
  if (!isnan(voc0) && !isnan(voc1) && (voc0 != 0.0f || voc1 != 0.0f)) {
    voc.set_states(voc0, voc1);         // Restore algorithm state
    Serial.println("VOC algorithm state restored from memory.");
  } else {
    Serial.println("VOC algorithm starting with default state.");
  }
}

// --- Function to put the chip into deep sleep for 10 minutes ---
void go_to_sleep() {
  Serial.println("Going to sleep for 10 minutes...");
  esp_wifi_stop();                      // Turn off WiFi to save power
  esp_deep_sleep(10 * 60 * 1000000ULL); // 10 minutes in microseconds
}

// --- Main program ---
void setup() {
  pinMode(POWER_ENABLE_PIN, OUTPUT);    // Set output pin for sensor power
  digitalWrite(POWER_ENABLE_PIN, HIGH); // Enable sensor power

  Serial.begin(115200);
  delay(300);

  // --- Connect to WiFi via WiFiManager (creates config AP if needed) ---
  WiFiManager wifiManager;
  wifiManager.autoConnect("ESP32-Config");

  // --- Initialize I2C bus ---
  Wire.begin(SDA_PIN, SCL_PIN);

  // --- Initialize BME688 (temperature, humidity, quality) ---
  if (!bme688.begin()) {
    Serial.println("BME688 not found!");
    digitalWrite(POWER_ENABLE_PIN, LOW);
    go_to_sleep();
  }

  // --- Initialize SCD41 (CO2) ---
  if (!scd41.begin(false, true)) {
    Serial.println("SCD41 not found!");
    digitalWrite(POWER_ENABLE_PIN, LOW);
    go_to_sleep();
  }
  scd41.startLowPowerPeriodicMeasurement(); // Start measurement in SCD41
  delay(5000); // Required for first valid measurement

  // --- Initialize SGP41 (VOC) and self-test ---
  sgp41.begin(Wire);
  uint16_t testResult;
  uint16_t error = sgp41.executeSelfTest(testResult);
  if (error || testResult != 0xD400) {
    Serial.print("SGP41 self-test failed! Error: ");
    Serial.println(error);
    digitalWrite(POWER_ENABLE_PIN, LOW);
    go_to_sleep();
  }

  // --- Load VOC algorithm state from NVS memory ---
  load_voc_state(voc_algorithm);

  // --- Measure temperature and humidity with BME688 ---
  sensors_event_t humidity, temp;
  float bme_temp = NAN, bme_rh = NAN;
  if (bme688.getEvent(&humidity, &temp)) {
    bme_temp = temp.temperature;
    bme_rh = humidity.relative_humidity;
  } else {
    bme_temp = 25.0;
    bme_rh = 50.0;
    Serial.println("BME688 read error! Using default values.");
  }

  // --- SGP41: 60x measurements (1 min, 1 Hz) with BME688 compensation ---
  float voc_index = 0;
  for (int i = 0; i < 60; i++) {
    // Convert values for compensation (see SGP41 datasheet)
    uint16_t compRH = (uint16_t)((bme_rh * 65535.0f) / 100.0f);
    uint16_t compT = (uint16_t)(((bme_temp + 45.0f) * 65535.0f) / 175.0f);

    uint16_t srawVoc = 0, srawNox = 0;
    uint16_t sgp41_error = sgp41.measureRawSignals(compRH, compT, srawVoc, srawNox);

    if (!sgp41_error) {
      voc_index = voc_algorithm.process(srawVoc); // Compute VOC index
    } else {
      Serial.print("SGP41 error: ");
      Serial.println(sgp41_error);
    }
    Serial.print("SGP41 ["); Serial.print(i+1); Serial.print("/60]: VOC="); Serial.println(voc_index, 1);

    delay(1000); // 1 Hz measurement
  }

  // --- Save VOC algorithm state after measurement ---
  save_voc_state(voc_algorithm);

  // --- SCD41: Wait for valid measurement (max 30s) ---
  float scd_co2 = NAN, scd_temp = NAN, scd_rh = NAN;
  bool scd_ok = false;
  unsigned long start = millis();
  while (millis() - start < 30000) {
    if (scd41.readMeasurement()) {
      scd_co2 = scd41.getCO2();
      scd_temp = scd41.getTemperature();
      scd_rh = scd41.getHumidity();
      scd_ok = true;
      break;
    }
    delay(500);
  }
  if (!scd_ok) {
    Serial.println("SCD41: Failed to get a valid measurement within the time limit.");
  }

  // --- Cut sensor power (POWER_ENABLE_PIN) ---
  digitalWrite(POWER_ENABLE_PIN, LOW);

  // --- Measure battery voltage via ADC ---
  float bat_voltage = analogReadMilliVolts(ADCBpin) * bDeviderRatio / 1000.0;
  Serial.print("Battery voltage = ");
  Serial.print(bat_voltage, 2);
  Serial.println(" V");

  // --- Print measured values to serial port ---
  Serial.println("Measured values:");
  Serial.print("BME688: T="); Serial.print(bme_temp, 2); Serial.print("°C, RH="); Serial.print(bme_rh, 2); Serial.println("%");
  Serial.print("SGP41: VOC="); Serial.println(voc_index, 1);
  Serial.print("SCD41: CO2="); Serial.print(scd_co2, 1); Serial.print("ppm, T="); Serial.print(scd_temp, 2); Serial.print("°C, RH="); Serial.print(scd_rh, 2); Serial.println("%");

  // --- Send data to server via HTTP GET ---
  if (WiFi.status() == WL_CONNECTED) {
    HTTPClient http;
    String serverPath = serverName +
      "temp=" + String(bme_temp, 2) +
      "&hum=" + String(bme_rh, 2) +
      "&co2=" + String(scd_co2, 1) +
      "&voc=" + String(voc_index, 1) +
      "&scdtemp=" + String(scd_temp, 2) +
      "&scdrh=" + String(scd_rh, 2) +
      "&v=" + String(bat_voltage, 2) +
      "&rssi=" + String(WiFi.RSSI());
    Serial.println("Sending: " + serverPath);

    http.begin(serverPath.c_str());
    int httpResponseCode = http.GET();
    if (httpResponseCode > 0) {
      Serial.print("HTTP Response code: ");
      Serial.println(httpResponseCode);
      String payload = http.getString();
      Serial.println(payload);
    } else {
      Serial.print("HTTP error: ");
      Serial.println(httpResponseCode);
    }
    http.end();
  } else {
    Serial.println("WiFi not connected, data not sent.");
  }

  // --- Put chip to sleep (deep sleep for 10 minutes) ---
  go_to_sleep();
}

void loop() {
  // Unused, everything is in setup()
}
